---
import { Icon } from "astro-icon/components";
---
<header>
    <a href="/" class="header-link">Joey Vongphasouk</a>

    <div class="burger-menu" id="burger-btn">
        <Icon name="BurgerMenu" width="40" height="40"/>
    </div>

    <nav class="rs-header-navbar" id="navbar">
        <a href="./blogs" class="header-link">Blogs</a>
        <a href="./projects" class="header-link">Projects</a>
        <a href="./about" class="header-link">About</a>
        <a href="./now" class="header-link">Now</a>
        <!-- <a href="./contact" class="header-link">Contact</a> -->
    </nav>

    <div class="mobile-sidebar-container" id="mobile-menu-container">
        <button class="sidebar-close" id="close-btn">
            <Icon name="XClose" width="24" height="24"/>
        </button>
        <div class="mobile-sidebar" id="mobile-menu">
            <a href="/">Home</a>
            <a href="./blogs">Blogs</a>
            <a href="./projects">Projects</a>
            <a href="./about">About</a>
            <a href="./now">Now</a>
            <!-- <a href="./contact">Contact</a> -->
        </div>
    </div>
    <div class="overlay" id="overlay"></div>
</header>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const burgerBtn = document.getElementById("burger-btn");
            const closeBtn = document.getElementById("close-btn");
            const overlay = document.getElementById("overlay");
            let isMenuOpen = false;
            if (!burgerBtn) return;
            if (!document.getElementById("overlay")) return;

            const closeMenu = () => {
                document.getElementById("overlay").classList.remove("active");
                document.getElementById("mobile-menu-container").classList.remove("active");
                isMenuOpen = false;
            };

            const openMenu = () => {
                document.getElementById("overlay").classList.add("active");
                document.getElementById("mobile-menu-container").classList.add("active");
                isMenuOpen = true;
            };

            burgerBtn?.addEventListener("click", () => {
                if (isMenuOpen) {
                    closeMenu();
                } else {
                    openMenu();
                }
            });

            closeBtn?.addEventListener("click", () => {
                closeMenu();
            });

            overlay?.addEventListener("click", () => {
                closeMenu();
            });
        });
    </script>