---
import { Image } from 'astro:assets';

interface Props {
  src: any;
  alt?: string;
  caption?: string;
}

const { src, alt = "", caption } = Astro.props as Props;
---

<figure class="blog-content-wrapper">
  <Image src={src} alt={alt} class="blog-image" />
  {caption && <figcaption>{caption}</figcaption>}
</figure>