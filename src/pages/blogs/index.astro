---
import Layout from '../../layouts/GeneralLayout.astro';
import { getCollection } from "astro:content";

const title = "Blog List";
const description = "Landing page for my blogs.";
const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime()
);
---

<Layout title={title} description={description}'>



<h1>Blogs:</h1>
<h2>Filters: lmao need to do pr</h2>
<ol class="max-w-md space-y-1 text-body list-disc list-inside mb-2">
  {sortedPosts.map((post) => (
    <li>
      <a href={`/blogs/${post.data.slug}`}>
        {post.data.title}
      </a>
    </li>
  ))}
</ol>


</Layout>





